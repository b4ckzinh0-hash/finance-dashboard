NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Pluggy Open Finance (https://pluggy.ai)
# Create an account and application at https://dashboard.pluggy.ai
PLUGGY_CLIENT_ID=your_pluggy_client_id
PLUGGY_CLIENT_SECRET=your_pluggy_client_secret

# Belvo Open Finance (https://belvo.com) — alternativa ao Pluggy
# Create an account at https://dashboard.belvo.com
BELVO_SECRET_ID=
BELVO_SECRET_PASSWORD=
# BELVO_ENVIRONMENT=sandbox  # 'sandbox' (padrão) ou 'production'
